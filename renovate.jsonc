{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "minimumReleaseAge": "14 days",
  "labels": [
    "deps"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ],
    "minimumReleaseAge": null
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "**/devcontainer.json"
      ],
      "matchStrings": [
        // JSON string following a `// renovate:` comment in the form `"tag@sha256:digest"`
        // e.g. "ubuntu:22.04@sha256:abc123..."
        "// renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?[\\s\\S]*?\"(?<currentValue>[^\"@]+)@(?<currentDigest>sha256:[a-f0-9]+)\"",
        // JSON string following a `// renovate:` comment in the form `"name@version"` (no sha256 digest)
        // e.g. "anthropic.claude-code@2.1.168"
        "// renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?[\\s\\S]*?\"[^\"@]+@(?<currentValue>[^\":]+)\"",
        // JSON key-value pair following a `// renovate:` comment where the value is a
        // plain version string (no `@`). Skips the quoted key first so currentValue
        // captures the value, not the key.
        // e.g. "MISE_VERSION": "2026.6.12"
        "// renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?( extractVersion=(?<extractVersion>\\S+))?[\\s\\S]*?\"[^\"]+\":\\s*\"(?<currentValue>[^@\"\\s]+)\""
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "**/build.yaml"
      ],
      "matchStrings": [
        // YAML key-value line following a `# renovate:` comment where the value is in the form `tag@sha256:digest`
        // e.g. GOLANG_TAG: "1.26.4-trixie@sha256:abc123..."
        "# renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?( extractVersion=(?<extractVersion>\\S+))?\\s+\\S+: \"?(?<currentValue>[^@\\s\"]+)@(?<currentDigest>sha256:[a-f0-9]+)",
        // YAML list item following a `# renovate:` comment with an explicit versioning= annotation (semver-like versioning, e.g. semver, node) where the value has a non-version suffix; captures only the version part
        // e.g. versioning=semver, - "0.16.0-trixie" → currentValue: "0.16.0"
        // e.g. versioning=node,   - "26.4.0-trixie" → currentValue: "26.4.0"
        "# renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)( extractVersion=(?<extractVersion>\\S+))?\\s+- \"(?<currentValue>[^\"\\-]+)(?:-[^\"]*)?\"",
        // YAML list item following a `# renovate:` comment with no versioning= annotation; captures the version as currentValue and the optional compatibility suffix (e.g. `-trixie`, `-bookworm`) as currentCompatibility
        // e.g. - "1.26.4-trixie" → currentValue: "1.26.4", currentCompatibility: "trixie"
        // e.g. - "1.26.4"        → currentValue: "1.26.4"
        // The \s+ between depName and the list item implicitly blocks this pattern from matching when versioning= (or any other token) appears before the newline, making a lookahead unnecessary.
        "# renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+)( extractVersion=(?<extractVersion>\\S+))?\\s+- \"(?<currentValue>[^\"\\-]+)(-(?<currentCompatibility>[^\"]+))?\"",
        // YAML key-value line following a `# renovate:` comment where the value is a plain version string (no digest)
        // e.g. ZIG_VERSION: "0.16.0" / MISE_VERSION: "2026.6.12"
        "# renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?( extractVersion=(?<extractVersion>\\S+))?\\s+\\S+: \"(?<currentValue>[^@\"\\s]+)\""
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}docker{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "**/.github/workflows/*.yml"
      ],
      "matchStrings": [
        // YAML key-value line following a `# renovate:` comment where the value is in the form `tag@sha256:digest`
        // e.g. DECOLINT_TAG: "latest@sha256:abc123..."
        "# renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?( extractVersion=(?<extractVersion>\\S+))?\\s+\\S+: \"?(?<currentValue>[^@\\s\"]+)@(?<currentDigest>sha256:[a-f0-9]+)",
        // YAML key-value line following a `# renovate:` comment where the value is a plain version string (no digest)
        // e.g. TRIVY_VERSION: "v0.71.2"
        "# renovate: datasource=(?<datasource>\\S+)( registryUrl=(?<registryUrl>\\S+))? depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?( extractVersion=(?<extractVersion>\\S+))?\\s+\\S+: \"(?<currentValue>[^@\"\\s]+)\""
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "Disable minimumReleaseAge for Docker images since Docker registries do not provide release timestamps.",
      "matchDatasources": [
        "docker"
      ],
      "minimumReleaseAge": null
    },
    {
      "description": "Apply dependency updates for published images without delay, since these are our own image build inputs and should be picked up promptly regardless of datasource.",
      "matchFileNames": [
        "**/build.yaml"
      ],
      "minimumReleaseAge": null
    },
    {
      "description": "Pin the Debian release to stay within the same major version (e.g., bookworm, trixie).",
      "matchFileNames": [
        "debian/build.yaml"
      ],
      "matchPackageNames": [
        "debian"
      ],
      "allowedVersions": "/^{{ lookup (split currentVersion '-') 0 }}-\\d{8}(?:\\.\\d+)?$/"
    },
    {
      "description": "Create separate patch update branches so older Go release lines (e.g. 1.25.x) still receive patch updates while minor updates are disabled below.",
      "matchFileNames": [
        "golang/build.yaml"
      ],
      "matchPackageNames": [
        "golang"
      ],
      "separateMinorPatch": true
    },
    {
      "matchFileNames": [
        "golang/build.yaml"
      ],
      "matchPackageNames": [
        "golang"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "zig/build.yaml"
      ],
      "matchPackageNames": [
        "ziglang/zig",
        "zigtools/zls"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "pin",
        "pinDigest"
      ],
      "enabled": false
    },
    {
      "groupName": "Dev Container",
      "matchFileNames": [
        ".devcontainer/**/*"
      ],
      "semanticCommitType": "chore"
    },
    {
      "groupName": "GitHub Actions",
      "matchFileNames": [
        ".github/workflows/*.yml"
      ],
      "semanticCommitType": "ci"
    },
    {
      "groupName": "Image Builds",
      "matchFileNames": [
        "**/build.yaml"
      ],
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "semanticCommitType": "image"
    }
  ]
}
