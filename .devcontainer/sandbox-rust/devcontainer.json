{
  "name": "sandbox-rust",
  "build": {
    "dockerfile": "../../rust/Dockerfile",
    "args": {
      // renovate: datasource=docker registryUrl=https://ghcr.io depName=bare-devcontainer/debian versioning=debian
      "DEBIAN_TAG": "trixie-20260723@sha256:b372ef12505e3efe7910c36902bddd1bba5bf1010450570260eeae9337879d15",
      // renovate: datasource=github-releases depName=rust-lang/rustup versioning=semver
      "RUSTUP_VERSION": "1.29.0"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "dev",
      "upgradePackages": false
    }
  },
  "containerEnv": {
    // rustup and cargo write into their home directories at runtime (toolchain
    // installs, the cargo package-cache lock directly under CARGO_HOME). Under
    // the read-only root filesystem the image's ~/.rustup and ~/.cargo are not
    // writable, and ~/.cargo cannot be replaced by a tmpfs without masking the
    // preinstalled rustup proxies in ~/.cargo/bin. Relocate both homes onto the
    // writable /tmp tmpfs instead; the PATH proxies honour these variables.
    "RUSTUP_HOME": "/tmp/rustup",
    "CARGO_HOME": "/tmp/cargo"
  },
  "runArgs": [
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges",
    "--read-only",
    "--tmpfs=/tmp:exec,mode=1777"
  ],
  "remoteUser": "dev"
}
