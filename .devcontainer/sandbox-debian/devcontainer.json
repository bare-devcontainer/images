{
  "name": "sandbox-debian",
  "build": {
    "dockerfile": "../../debian/Dockerfile",
    "args": {
      // renovate: datasource=docker depName=debian versioning=debian
      "DEBIAN_TAG": "trixie-20260713@sha256:fac46bff2e02f51425b6e33b0e1169f55dfb053d83511ca28aa50c09fd5ed7a4"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      // Configure the feature for the image's existing non-root user instead of
      // creating a new one.
      "username": "dev",
      // Skip the apt upgrade to keep the feature install fast and deterministic.
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/git-lfs:1": {}
  },
  "runArgs": [
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges"
  ],
  "remoteUser": "dev"
}
